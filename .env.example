# Copy to .env.local for local development

# PostgreSQL connection string (optional — APIs fall back to mock JSON when unset)
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/homezone

# Used by server components when calling local API routes during SSR
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Enables the embedded Google Map on the home page (Maps Embed API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
