# Copy to .env.local for local development

# PostgreSQL connection string (optional, APIs fall back to mock JSON when unset)
DATABASE_URL=postgres://group52:CIS-5500-Gr0uP-Pr0J3cT@cis-550-final-project.cvgflbojg9r8.us-east-1.rds.amazonaws.com:5432/postgres?sslmode=require

# Used by server components when calling local API routes during SSR
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Firebase (Auth + Firestore)
# Create a Firebase project, then add a Web App to get these values.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Optional (server-side token verification in API routes)
# Paste the FULL service account JSON as one line (escape newlines if needed).
FIREBASE_SERVICE_ACCOUNT_JSON=
